          <ul class="space-y-3 text-gray-600">
            <li>✓ 清除缓存</li>
            <li>✓ 关闭进程</li>
            <li>✓ 网络重置</li>
          </ul>
        </div>
        <div class="rounded-2xl p-8 bg-blue-600 text-white ring-4 ring-blue-300 scale-105">
          <div class="text-sm font-bold mb-2">⭐ 推荐</div>
          <h3 class="text-xl font-bold mb-4">标准诊断</h3>
          <div class="text-4xl font-bold mb-6">¥15</div>
          <ul class="space-y-3">
            <li>✓ 驱动修复</li>
            <li>✓ 系统优化</li>
            <li>✓ 软件冲突</li>
          </ul>
        </div>
        <div class="rounded-2xl p-8 bg-gray-50">
          <h3 class="text-xl font-bold mb-4 text-gray-900">深度诊断</h3>
          <div class="text-4xl font-bold mb-6">¥30</div>
          <ul class="space-y-3 text-gray-600">
            <li>✓ 病毒清理</li>
            <li>✓ 全面优化</li>
            <li>✓ 深度检测</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 bg-blue-600">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">电脑有问题？让 AI 帮你搞定！</h2>
      <a href="#download" class="inline-block bg-white text-blue-600 px-10 py-4 rounded-xl text-lg font-bold hover:bg-gray-100 transition">立即免费下载</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 px-4 bg-gray-900 text-gray-400">
    <div class="max-w-6xl mx-auto text-center">
      <p>© 2026 Jpair</p>
      <div class="mt-4 flex justify-center gap-6">
        <a href="#" class="hover:text-white">用户协议</a>
        <a href="#" class="hover:text-white">隐私政策</a>
        <a href="#" class="hover:text-white">联系我们</a>
