<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jpair - AI 帮你修电脑</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    html { scroll-behavior: smooth; }
  </style>
</head>
<body class="bg-white">
  <!-- Header -->
  <header class="fixed top-0 w-full bg-white/95 backdrop-blur shadow-sm z-50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="text-2xl">🤖</span>
        <span class="text-xl font-bold text-gray-800">Jpair</span>
      </div>
      <nav class="hidden md:flex items-center gap-8">
        <a href="#features" class="text-gray-600 hover:text-blue-600">功能介绍</a>
        <a href="#howto" class="text-gray-600 hover:text-blue-600">使用流程</a>
        <a href="#pricing" class="text-gray-600 hover:text-blue-600">价格</a>
      </nav>
      <a href="#download" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition">立即下载</a>
